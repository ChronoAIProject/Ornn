# ============================================================
# Dependency Service Environment Variables
# Copy to .env.dependencies and fill in actual values
# ============================================================

# -- Kubernetes --
NAMESPACE=<namespace>
IMAGE_PULL_POLICY=<Never-or-Always>

# -- MongoDB --
MONGODB_IMAGE_TAG=<mongodb-version>
MONGODB_PVC_NAME=<pvc-name>
MONGODB_HOST_PATH=<host-path-to-mongodb-data>
MONGO_ROOT_USERNAME=<mongo-root-username>
MONGO_ROOT_PASSWORD=<mongo-root-password>
MONGO_INIT_DB=<mongo-init-database>

# -- MinIO --
MINIO_IMAGE=<minio-image>
MINIO_PVC_NAME=<pvc-name>
MINIO_HOST_PATH=<host-path-to-minio-data>
MINIO_ROOT_USER=<minio-root-user>
MINIO_ROOT_PASSWORD=<minio-root-password>
MINIO_STS_USER=<minio-sts-user>
MINIO_STS_PASSWORD=<minio-sts-password>

# -- NyxID Backend --
NYXID_KEYS_DIR=<path-to-directory-containing-private.pem-and-public.pem>
NYXID_BACKEND_IMAGE=<nyxid-backend-image>
NYXID_PORT=<port>
NYXID_BASE_URL=<nyxid-base-url>
NYXID_FRONTEND_URL=<nyxid-frontend-url>
NYXID_DATABASE_MAX_CONNECTIONS=<max-connections>
NYXID_JWT_PRIVATE_KEY_PATH=<jwt-private-key-path>
NYXID_JWT_PUBLIC_KEY_PATH=<jwt-public-key-path>
NYXID_JWT_ACCESS_TTL_SECS=<access-token-ttl>
NYXID_JWT_REFRESH_TTL_SECS=<refresh-token-ttl>
NYXID_RATE_LIMIT_PER_SECOND=<rate-limit>
NYXID_RATE_LIMIT_BURST=<rate-limit-burst>
NYXID_SMTP_HOST=<smtp-host>
NYXID_SMTP_PORT=<smtp-port>
NYXID_SMTP_FROM_ADDRESS=<smtp-from-address>
NYXID_CORS_ALLOWED_ORIGINS=<cors-allowed-origins>
NYXID_RUST_LOG=<rust-log-level>
NYXID_DATABASE_URL=<nyxid-database-url>
NYXID_ENCRYPTION_KEY=<nyxid-encryption-key>

# -- NyxID Frontend --
NYXID_FRONTEND_IMAGE=<nyxid-frontend-image>
NYXID_FRONTEND_BACKEND_URL=<nyxid-backend-url>

# -- chrono-storage --
CHRONO_STORAGE_IMAGE=<chrono-storage-image>
CHRONO_STORAGE_PORT=<port>
CHRONO_STORAGE_S3_ENDPOINT=<s3-endpoint-url>
CHRONO_STORAGE_S3_REGION=<s3-region>
CHRONO_STORAGE_S3_SIGNED_URL_EXPIRATION_SEC=<signed-url-ttl>
CHRONO_STORAGE_IDLE_TIMEOUT=<idle-timeout>
CHRONO_STORAGE_LOG_LEVEL=<log-level>
CHRONO_STORAGE_LOG_PRETTY=<true-or-false>
CHRONO_STORAGE_S3_AUTH_MODE=<auth-mode>
S3_ACCESS_KEY=<s3-access-key>
S3_SECRET_KEY=<s3-secret-key>

# -- chrono-sandbox --
CHRONO_SANDBOX_IMAGE=<chrono-sandbox-image>
CHRONO_SANDBOX_HOST=<host>
CHRONO_SANDBOX_PORT=<port>
CHRONO_SANDBOX_RUST_LOG=<rust-log-level>
CHRONO_SANDBOX_OPENSANDBOX_URL=<opensandbox-url>
CHRONO_SANDBOX_OPENSANDBOX_API_KEY=<opensandbox-api-key>
CHRONO_SANDBOX_OPENSANDBOX_IMAGE=<opensandbox-image>
CHRONO_SANDBOX_SANDBOX_TIMEOUT_SECS=<sandbox-timeout>
CHRONO_SANDBOX_EXECUTION_TIMEOUT_SECS=<execution-timeout>
CHRONO_SANDBOX_EXECUTION_TIMEOUT_MAX_SECS=<execution-timeout-max>
CHRONO_SANDBOX_DEPENDENCY_INSTALL_TIMEOUT_SECS=<dependency-install-timeout>
CHRONO_SANDBOX_MAX_OUTPUT_FILE_SIZE_BYTES=<max-output-file-size>
CHRONO_SANDBOX_MAX_OUTPUT_TOTAL_SIZE_BYTES=<max-output-total-size>
CHRONO_SANDBOX_MAX_DEPENDENCIES=<max-dependencies>
CHRONO_SANDBOX_MAX_STDOUT_BYTES=<max-stdout>
CHRONO_SANDBOX_MAX_STDERR_BYTES=<max-stderr>
CHRONO_SANDBOX_DEFAULT_CPU=<default-cpu>
CHRONO_SANDBOX_DEFAULT_MEMORY=<default-memory>
CHRONO_SANDBOX_MAX_CPU_MILLICORES=<max-cpu>
CHRONO_SANDBOX_MAX_MEMORY_MB=<max-memory>
CHRONO_SANDBOX_SESSION_TTL_SECS=<session-ttl>
CHRONO_SANDBOX_SESSION_MAX_TTL_SECS=<session-max-ttl>
CHRONO_SANDBOX_SESSION_CLEANUP_INTERVAL_SECS=<cleanup-interval>
CHRONO_SANDBOX_MAX_SESSIONS=<max-sessions>
CHRONO_SANDBOX_MAX_INPUT_FILES=<max-input-files>
CHRONO_SANDBOX_MAX_INPUT_FILE_SIZE_BYTES=<max-input-file-size>
CHRONO_SANDBOX_MAX_INPUT_TOTAL_SIZE_BYTES=<max-input-total-size>
