# ============================================================
# Ornn Environment Variables
# Copy to .env.ornn and fill in actual values
# ============================================================

# -- Kubernetes --
NAMESPACE=<namespace>
IMAGE_PULL_POLICY=<Never-or-Always>
# minio Service ClusterIP. Used as a pod hostAlias so ornn-api (audit path
# fetches skill zips via presigned URLs) resolves `minio.ornn-cluster.local`
# to the same target the browser does. Get it with:
#   kubectl get svc minio -n <namespace> -o jsonpath='{.spec.clusterIP}'
# Must be set to the SAME value as MINIO_HOST_ALIAS_IP in .env.dependencies.
MINIO_HOST_ALIAS_IP=<minio-service-cluster-ip>

# -- ornn-api (runtime env vars) --
ORNN_API_IMAGE=<ornn-api-image>
ORNN_API_PORT=<port>
ORNN_API_LOG_LEVEL=<log-level>
ORNN_API_LOG_PRETTY=<true-or-false>
# NyxID service-account credentials (machine-to-machine, client_credentials grant).
# Used by ornn-api to mint SA tokens for server-side NyxID calls (org lookups, etc).
# Distinct from the OAuth public client used by the browser (see below).
NYXID_SA_TOKEN_URL=<nyxid-token-url>
NYXID_SA_CLIENT_ID=<nyxid-sa-client-id>
NYXID_SA_CLIENT_SECRET=<nyxid-sa-client-secret>
NYX_LLM_GATEWAY_URL=<nyx-llm-gateway-url>
MONGODB_URI=<mongodb-uri>
MONGODB_DB=<mongodb-database-name>
STORAGE_SERVICE_URL=<chrono-storage-url>
STORAGE_BUCKET=<storage-bucket-name>
SANDBOX_SERVICE_URL=<chrono-sandbox-url>
DEFAULT_LLM_MODEL=<default-llm-model>
LLM_MAX_OUTPUT_TOKENS=<max-output-tokens>
LLM_TEMPERATURE=<temperature>
SSE_KEEP_ALIVE_INTERVAL_MS=<keep-alive-ms>
MAX_PACKAGE_SIZE_BYTES=<max-package-size>
ALLOWED_ORIGINS=<comma-separated-origins, e.g. https://app.ornn.xyz,http://localhost:5173>
# Synthetic / out-of-catalogue NyxID services appended to the bottom of
# every GET /me/nyxid-services response. Pickers in the skill UI list
# these after every real catalogue entry so operators can surface a
# platform-side option that isn't (yet) registered. Comma-separated.
# Default is "NyxID"; extend to e.g. "NyxID,SomeOtherSvc" without code.
EXTRA_NYXID_SERVICES=<comma-separated, e.g. NyxID>

# -- ornn-web (runtime env vars — injected via ConfigMap at container start) --
ORNN_WEB_IMAGE=<ornn-web-image>
# nginx upstream targets (consumed by /etc/nginx/templates/default.conf.template)
NYXID_BACKEND_URL=<nyxid-backend-url>
# Hostname portion of NYXID_BACKEND_URL — used for Host header + SNI.
# Required when the upstream is behind a multi-tenant HTTPS edge (Cloudflare,
# Vercel, etc.) — without it TLS handshake fails with alert 40.
# e.g. NYXID_BACKEND_URL=https://nyx.chrono-ai.fun → NYXID_BACKEND_HOST=nyx.chrono-ai.fun
NYXID_BACKEND_HOST=<nyxid-backend-host>
ORNN_API_URL=<ornn-api-url>
# Frontend runtime config (injected into window.__ORNN_CONFIG__ via /config.js)
API_BASE_URL=<api-base-url-for-frontend>
NYXID_LOGOUT_URL=<nyxid-logout-url>
NYXID_SETTINGS_URL=<nyxid-settings-url>
# NyxID OAuth (authorization_code + PKCE) — used by the browser for end-user
# sign-in. A PUBLIC client (no secret). Distinct from the SA credentials above:
# ornn-api uses SA for machine-to-machine, the browser uses OAuth for the user.
NYXID_OAUTH_AUTHORIZE_URL=<nyxid-authorize-url>
NYXID_OAUTH_TOKEN_URL=<browser-reachable-nyxid-token-url>
NYXID_OAUTH_CLIENT_ID=<public-oauth-client-id>
NYXID_OAUTH_REDIRECT_URI=<oauth-redirect-uri>
